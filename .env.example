# Postgres connection string (Neon, local docker, or any Postgres 14+)
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Single Alchemy team API key — works across all enabled networks (mainnet, arbitrum, optimism, base)
ALCHEMY_KEY=

# Pendle V2 hosted API base URL (no auth)
PENDLE_API_BASE=https://api-v2.pendle.finance/core
